{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nimbus",
  "version": "0.1.2",
  "identifier": "app.nimbusflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Nimbus",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["nimbus"],
        "name": "Nimbus Flow",
        "description": "Nimbus debate flow",
        "role": "Editor",
        "mimeType": "application/json"
      }
    ]
  }
}
